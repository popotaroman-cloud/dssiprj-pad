' โมดูล 7: Admin — การจัดการระบบ (UC-24, UC-25)
' ไม่มีความสัมพันธ์ข้ามโมดูลเชิง include/extend
' UC-25 (ดูและตอบกลับ Feedback) เกี่ยวข้องกับ UC-06 (โมดูล 1) เชิงข้อมูลเท่านั้น (ใช้ข้อมูล Feedback ร่วมกัน)
' แอดมินไม่มี use case จัดการรูปแบบอวตารอีกต่อไป (ตัดออกจากขอบเขต)
@startuml usecase_module7
!theme plain
skinparam defaultFontName TH Sarabun New
skinparam defaultFontSize 14
skinparam roundcorner 10

skinparam usecase {
  BackgroundColor #FFFDE7
  BorderColor #795548
}
skinparam actor {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
}
skinparam package {
  BackgroundColor #F5F5F5
  BorderColor #757575
  FontStyle bold
}
skinparam rectangle {
  BackgroundColor #FCFCFC
  BorderColor #9E9E9E
}
skinparam ArrowColor #424242

title <b>แอปพลิเคชัน Focus</b>\n(Use Case Diagram — โมดูล 7 · Admin — การจัดการระบบ)

left to right direction

actor "ผู้ดูแลระบบ\n(Admin)" as Admin

rectangle "โมดูล 7 · Admin — การจัดการระบบ" {
  package "E1 · การจัดการเนื้อหาเกม" {
    usecase "UC-24\nจัดการข้อมูลไอเทม\nและอัตราดรอป\n(เพิ่ม/แก้ไข/ลบ/ปิดใช้งาน)" as UC24
  }

  package "E2 · การจัดการ Feedback ผู้ใช้" {
    usecase "UC-25\nดูและตอบกลับ Feedback" as UC25
  }
}

Admin -- UC24
Admin -- UC25

@enduml
