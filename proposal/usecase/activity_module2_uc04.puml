@startuml M2_activity_เริ่มจับเวลาโฟกัส
!pragma layout smetana
skinparam defaultFontName "TH Sarabun New"
skinparam defaultFontSize 14

!theme plain
skinparam titleFontName "TH Sarabun New"
skinparam titleFontSize 20
skinparam noteFontName "TH Sarabun New"
skinparam ArrowFontName "TH Sarabun New"
skinparam ArrowFontSize 12
skinparam swimlaneTitleFontName "TH Sarabun New"
skinparam swimlaneTitleFontSize 14

skinparam activity {
  BackgroundColor #F5F5F5
  BorderColor #424242
  FontName "TH Sarabun New"
  FontSize 13
  DiamondBackgroundColor #FAFAFA
  DiamondBorderColor #616161
}

title UC-04 เริ่มจับเวลาโฟกัส (ตีบอส) — Activity Diagram

|สมาชิก|
start
:เลือกรายการที่จะโฟกัส (จาก UC-03)\nและตั้งระยะเวลาโฟกัส/พักส่วนตัว;

|ระบบ|
if (HP อวตาร = 0?) then (ใช่ — หมดสติ)
  :แจ้งสถานะ "หมดสติ"\nล็อกการเริ่มเซสชัน;
  |สมาชิก|
  :ไปชุบชีวิตอวตาร (UC-30);
  stop
else (ไม่ — ยังไหว)
endif

:สร้างบอส (HP = เวลาที่ตั้ง × 100);
:เริ่มจับเวลาถอยหลัง;

|สมาชิก|
repeat
  :ดูนาฬิกาถอยหลังลดลงวินาทีต่อวินาทีบนหน้าจอ;
  if (กดค้างยกเลิกเซสชันหรือไม่?) then (ยกเลิก)
    |ระบบ|
    :คืน HP อวตารตามสัดส่วนเวลาที่ทำไป;
    :บันทึกเซสชันว่า "ยกเลิก";
    :ไม่แจกกล่องสุ่ม;
    stop
  else (ทำต่อ)
  endif
  |ระบบ|
  if (ผ่านไปครบทุก 5 นาทีหรือไม่?) then (ใช่)
    :คำนวณหักลดเลือด HP บอส (ส่งดาเมจ);
  else (ไม่ใช่)
  endif
repeat while (เวลาครบหรือไม่?) is (ยังไม่ครบ) not (ครบ)

|ระบบ|
:คืน HP อวตาร;
:บันทึกเซสชันสำเร็จลงประวัติ;

if (ระยะเวลาโฟกัส ≥ 20 นาที?) then (ใช่)
  :แจก EXP ให้อวตาร;
  :แจกกล่องสุ่มตามความยาวเซสชัน\n(เปิดใน UC-10);
else (ไม่ — น้อยกว่า 20 นาที)
  :ไม่แจก EXP / กล่องสุ่ม;
endif

:เริ่มนับเวลาพักอัตโนมัติตามที่ตั้งไว้;

|สมาชิก|
if (กดข้ามช่วงพักก่อนกำหนด?) then (ใช่)
  :เริ่มเซสชันใหม่ทันที;
  stop
else (รอจนครบ / ไม่กดอะไร)
endif

|ระบบ|
:แจ้งว่าช่วงพักสิ้นสุดแล้ว;
:นับเวลาพักเกินกำหนดเป็นสถิติ\nหากไม่เริ่มเซสชันใหม่;

stop

@enduml
