@startuml M1_activity_จัดการรายการสิ่งที่โฟกัส
!pragma layout smetana
skinparam defaultFontName "TH Sarabun New"
skinparam defaultFontSize 14

!theme plain
skinparam titleFontName "TH Sarabun New"
skinparam titleFontSize 20
skinparam noteFontName "TH Sarabun New"
skinparam ArrowFontName "TH Sarabun New"
skinparam ArrowFontSize 12
skinparam swimlaneTitleFontName "TH Sarabun New"
skinparam swimlaneTitleFontSize 14

skinparam activity {
  BackgroundColor #F5F5F5
  BorderColor #424242
  FontName "TH Sarabun New"
  FontSize 13
  DiamondBackgroundColor #FAFAFA
  DiamondBorderColor #616161
}

title UC-03 จัดการรายการสิ่งที่โฟกัส (เพิ่ม/ลบ) — Activity Diagram

|สมาชิก|
start
:เปิดหน้าจัดการรายการสิ่งที่โฟกัส;

if (ต้องการเพิ่มหรือลบรายการ?) then (เพิ่มรายการ)

  repeat
    :กรอกชื่อรายการที่จะโฟกัส;
    |ระบบ|
    if (กรอกชื่อรายการหรือไม่?) then (ไม่กรอก)
      :แจ้งเตือนให้กรอกชื่อรายการ;
      |สมาชิก|
    else (กรอกแล้ว)
    endif
  repeat while (กรอกชื่อรายการแล้วหรือไม่?) is (ยังไม่กรอก) not (กรอกแล้ว)

  |สมาชิก|
  :กดเพิ่ม;
  |ระบบ|
  :บันทึกรายการลงในลิสต์;

else (ลบรายการ)

  |สมาชิก|
  :เลือกรายการที่ไม่ต้องการแล้วและกดลบ;
  |ระบบ|
  :ลบรายการออกจากลิสต์;
  note right
    รายการที่ถูกลบจะไม่แสดงเป็นตัวเลือก
    ในขั้นตอนที่ 1 ของ UC-07 อีกต่อไป
    แต่เซสชันประวัติที่เคยใช้รายการนี้มาก่อน (UC-23)
    ยังคงเก็บชื่อรายการเดิมไว้ พร้อมระบุว่าถูกลบแล้ว
  end note

endif

note right
  ไม่มีฟีเจอร์แก้ไขชื่อรายการที่เพิ่มไปแล้ว
  หากต้องการเปลี่ยนชื่อ ต้องลบรายการเดิม
  แล้วเพิ่มรายการใหม่แทน
end note

stop

legend right
  |<back:white>    </back>| Actor ภายนอก (human) |
  |<back:#F5F5F5>    </back>| ระบบ (monolith — เลนเดียว) |
endlegend

@enduml
