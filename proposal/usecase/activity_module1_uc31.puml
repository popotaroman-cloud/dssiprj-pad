@startuml M1_activity_เข้าสู่ระบบ
!pragma layout smetana
skinparam defaultFontName "TH Sarabun New"
skinparam defaultFontSize 14

!theme plain
skinparam titleFontName "TH Sarabun New"
skinparam titleFontSize 20
skinparam noteFontName "TH Sarabun New"
skinparam ArrowFontName "TH Sarabun New"
skinparam ArrowFontSize 12
skinparam swimlaneTitleFontName "TH Sarabun New"
skinparam swimlaneTitleFontSize 14

skinparam activity {
  BackgroundColor #F5F5F5
  BorderColor #424242
  FontName "TH Sarabun New"
  FontSize 13
  DiamondBackgroundColor #FAFAFA
  DiamondBorderColor #616161
}

title UC-31 เข้าสู่ระบบ — Activity Diagram

|สมาชิก|
start
:เปิดแอป เห็นหน้าล็อกอิน;
:กรอกอีเมล/ชื่อผู้ใช้และรหัสผ่าน;
:กดยืนยันเข้าสู่ระบบ;

|ระบบ|
:ตรวจสอบข้อมูลกับฐานข้อมูลผู้ใช้;

if (ข้อมูลถูกต้องหรือไม่?) then (ไม่ถูกต้อง)
  :แจ้งเตือน ไม่ออก token;
  stop
else (ถูกต้อง)
endif

if (บัญชีถูกระงับหรือไม่? (UC-28)) then (ถูกระงับ)
  :แจ้งเตือนว่าบัญชีถูกระงับพร้อมเหตุผล ไม่อนุญาตให้เข้าสู่ระบบ;
  stop
else (ไม่ถูกระงับ)
endif

:ออก token ยืนยันตัวตน;

|สมาชิก|
:เข้าสู่หน้าหลัก;

stop

@enduml
