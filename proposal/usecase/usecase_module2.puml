' โมดูล 2: เซสชันโฟกัส (Core Loop) — UC-07, UC-08, UC-09
' UC-08 (เข้าสู่ระบบ)/UC-09 (ออกจากระบบ) อยู่ในโมดูลนี้ตามรหัส FN-SES-002/003
' (ดู usecase_description.md — E1 · วงจรเซสชันโฟกัส และ E3 · การเข้าสู่ระบบและออกจากระบบ)
' รับความสัมพันธ์ <<include>> เข้ามาจาก UC-15 (โมดูล 4) — วาดไว้ที่ไฟล์โมดูล 4 แทน ไม่วาดซ้ำที่นี่
@startuml usecase_module2
!theme plain
skinparam defaultFontName TH Sarabun New
skinparam defaultFontSize 14

skinparam usecase {
  BackgroundColor #FFFDE7
  BorderColor #795548
  FontName TH Sarabun New
  FontSize 15
}
skinparam actor {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
}
skinparam ArrowColor #424242

title <b>แอปพลิเคชัน Focus</b>\n(Use Case Diagram — โมดูล 2 · เซสชันโฟกัส)

left to right direction

actor "สมาชิก\n(Member)" as Member
actor "ผู้ดูแลระบบ\n(Admin)" as Admin

rectangle "โมดูล 2 · เซสชันโฟกัส (Core Loop)" {
  package "E1 · วงจรเซสชันโฟกัส" {
    usecase "UC-07\nเริ่มจับเวลาโฟกัส\n(ตีบอส)" as UC07
  }

  package "E3 · การเข้าสู่ระบบและออกจากระบบ" {
    usecase "UC-08\nเข้าสู่ระบบ" as UC08
    usecase "UC-09\nออกจากระบบ" as UC09
  }
}

Member -- UC07
Member -- UC08
Member -- UC09
Admin -- UC08
Admin -- UC09

@enduml
