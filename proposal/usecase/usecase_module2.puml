' โมดูล 2: เซสชันโฟกัส (Core Loop) — UC-04, UC-31, UC-32
' UC-31 (เข้าสู่ระบบ)/UC-32 (ออกจากระบบ) ย้ายมาจากโมดูล 1 ตามรหัส FN-SES-002/003
' (ดูหมายเหตุข้อ 8(ข) ใน usecase_description.md)
@startuml usecase_module2
!theme plain
skinparam defaultFontName TH Sarabun New
skinparam defaultFontSize 14

skinparam usecase {
  BackgroundColor #FFFDE7
  BorderColor #795548
  FontName TH Sarabun New
  FontSize 15
}
skinparam actor {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
}
skinparam ArrowColor #424242

title <b>แอปพลิเคชัน Focus</b>\n(Use Case Diagram — โมดูล 2 · เซสชันโฟกัส)

left to right direction

actor "สมาชิก\n(Member)" as Member
actor "ผู้ดูแลระบบ\n(Admin)" as Admin

rectangle "โมดูล 2 · เซสชันโฟกัส (Core Loop)" {
  package "E1 · วงจรเซสชันโฟกัส" {
    usecase "UC-04\nเริ่มจับเวลาโฟกัส\n(ตีบอส)" as UC04
  }

  package "E3 · การเข้าสู่ระบบและออกจากระบบ" {
    usecase "UC-31\nเข้าสู่ระบบ" as UC31
    usecase "UC-32\nออกจากระบบ" as UC32
  }
}

Member -- UC04
Member -- UC31
Member -- UC32
Admin -- UC31
Admin -- UC32

@enduml
