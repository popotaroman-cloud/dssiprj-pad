' โมดูล 1: บัญชีและการเริ่มต้นใช้งาน (UC-01, UC-02, UC-03, UC-33, UC-38, UC-37)
' UC-31 (เข้าสู่ระบบ) และ UC-32 (ออกจากระบบ) ย้ายไปอยู่โมดูล 2 (usecase_module2.puml)
' ตามรหัส FN-SES-002/003 — ดูหมายเหตุข้อ 8(ข) ใน usecase_description.md
' ไม่มีความสัมพันธ์ข้ามโมดูล — เป็นจุดเริ่มต้นของทุกโมดูลอื่น
@startuml usecase_module1
!theme plain
skinparam defaultFontName TH Sarabun New
skinparam defaultFontSize 14
skinparam roundcorner 10

skinparam usecase {
  BackgroundColor #FFFDE7
  BorderColor #795548
}
skinparam actor {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
}
skinparam package {
  BackgroundColor #F5F5F5
  BorderColor #757575
  FontStyle bold
}
skinparam rectangle {
  BackgroundColor #FCFCFC
  BorderColor #9E9E9E
}
skinparam ArrowColor #424242

title <b>แอปพลิเคชัน Focus</b>\n(Use Case Diagram — โมดูล 1 · บัญชีและการเริ่มต้นใช้งาน)

left to right direction

actor "ผู้ใช้ทั่วไป\n(Guest)" as Guest
actor "สมาชิก\n(Member)" as Member

rectangle "โมดูล 1 · บัญชีและการเริ่มต้นใช้งาน" {
  package "E1 · การสมัครสมาชิกและสร้างอวตาร" {
    usecase "UC-01\nสมัครสมาชิก" as UC01
    usecase "UC-02\nสร้างอวตาร" as UC02
  }

  package "E2 · การเตรียมพร้อมก่อนเริ่มโฟกัส" {
    usecase "UC-03\nจัดการรายการสิ่งที่โฟกัส\n(เพิ่ม/แก้ไข/ลบ)" as UC03
  }

  package "E3 · การจัดการบัญชีและการตั้งค่า" {
    usecase "UC-33\nแก้ไขโปรไฟล์และ\nเปลี่ยนรหัสผ่าน" as UC33
    usecase "UC-38\nลืมรหัสผ่าน\n(Forgot Password)" as UC38
    usecase "UC-37\nตั้งค่าระยะเวลาเริ่มต้น\nของโฟกัส/พัก" as UC37
  }
}

Guest -- UC01
Guest -- UC38
Member -- UC03
Member -- UC33
Member -- UC37

UC01 ..> UC02 : <<include>>

@enduml
