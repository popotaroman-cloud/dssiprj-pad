@startuml M1_activity_การสมัครสมาชิก
!pragma layout smetana
skinparam defaultFontName "TH Sarabun New"
skinparam defaultFontSize 14

!theme plain
skinparam titleFontName "TH Sarabun New"
skinparam titleFontSize 20
skinparam noteFontName "TH Sarabun New"
skinparam ArrowFontName "TH Sarabun New"
skinparam ArrowFontSize 12
skinparam swimlaneTitleFontName "TH Sarabun New"
skinparam swimlaneTitleFontSize 14

skinparam activity {
  BackgroundColor #F5F5F5
  BorderColor #424242
  FontName "TH Sarabun New"
  FontSize 13
  DiamondBackgroundColor #FAFAFA
  DiamondBorderColor #616161
}

title UC-01 การสมัครสมาชิก — Activity Diagram

|Guest|
start
:กดปุ่ม "สมัครสมาชิก";

|ระบบ|
:แสดงฟอร์มกรอกข้อมูล;

|Guest|
repeat
  if (ต้องการยกเลิกกลางคันหรือไม่?) then (ยกเลิก)
    :ล้างข้อมูล กลับหน้าแรก (ยังเป็น Guest);
    stop
  else (กรอกข้อมูลต่อ)
  endif
  :กรอกข้อมูลครบถ้วนและกดยืนยัน;
  |ระบบ|
  :ตรวจสอบความถูกต้องของข้อมูล\n(ครบถ้วน ถูกรูปแบบ และอีเมล/ชื่อผู้ใช้ไม่ซ้ำ);
  if (ข้อมูลผ่านการตรวจสอบหรือไม่?) then (ไม่ผ่าน — ไม่ครบ/ไม่ถูกรูปแบบ/อีเมลหรือชื่อผู้ใช้ถูกใช้แล้ว)
    :แจ้งเตือนให้แก้ไขข้อมูล;
    |Guest|
  else (ผ่าน)
  endif
repeat while (ข้อมูลผ่านการตรวจสอบหรือไม่?) is (ไม่ผ่าน) not (ผ่านแล้ว)

|ระบบ|
:สร้างบัญชีใหม่ บันทึกลงฐานข้อมูล;
:เปลี่ยนสถานะจาก Guest เป็นสมาชิก;
:พาไปหน้าสร้างอวตาร (<<include>> UC-02);

stop

legend right
  |<back:white>    </back>| Actor ภายนอก (human) |
  |<back:#F5F5F5>    </back>| ระบบ (monolith — เลนเดียว) |
endlegend

@enduml
