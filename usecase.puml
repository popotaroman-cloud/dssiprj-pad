UC13 ..> EXT_MD_DUP    : <<include>>
UC13 ..> SYS7          : <<include>>
UC14 ..> EXT_MD_SNAP   : <<include>>
UC14 ..> SYS7          : <<include>>
UC15 ..> EXT_MD_USAGE  : <<include>>
UC15 ..> SYS7          : <<include>>

UC16 ..> EXT_MD_DUP    : <<include>>
UC16 ..> EXT_MD_SNAP   : <<include>>
UC16 ..> EXT_MD_USAGE  : <<include>>
UC16 ..> SYS7          : <<include>>

UC17 ..> EXT_MD_DUP    : <<include>>
UC17 ..> EXT_MD_USAGE  : <<include>>
UC17 ..> SYS7          : <<include>>

UC18 ..> EXT_MD_DUP    : <<include>>
UC18 ..> EXT_MD_USAGE  : <<include>>
UC18 ..> SYS7          : <<include>>

