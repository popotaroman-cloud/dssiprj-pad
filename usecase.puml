@startuml usecase
!theme plain
skinparam defaultFontName TH Sarabun New
skinparam defaultFontSize 14
skinparam roundcorner 10

skinparam usecase {
  BackgroundColor #FFFDE7
  BorderColor #795548
}
skinparam actor {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
}
skinparam package {
  BackgroundColor #F5F5F5
  BorderColor #757575
  FontStyle bold
}
skinparam rectangle {
  BackgroundColor #FCFCFC
  BorderColor #9E9E9E
}
skinparam ArrowColor #424242
skinparam noteBackgroundColor #FFF8E1
skinparam noteBorderColor #FF8F00

title <b>ระบบฟอร์มเสนอโครงการ</b>\n(Project Proposal Form System — FRD-PMS-001 v1.2)

left to right direction

actor "ผู้เสนอโครงการ\n(Proposer)" as Proposer #E3F2FD
actor "ผู้ดูแลระบบ\n(Admin)" as Admin #F3E5F5
actor "ระบบ\n(System)" as System #E8F5E9
actor "ผู้อนุมัติ\n(Approver)\n[นอกขอบเขต FRD]" as Approver #FFF8E1

rectangle "ระบบฟอร์มเสนอโครงการ" {

  ' ===== Use Cases หลัก =====
  usecase "UC-01\nสร้างร่างโครงการ\n(Create Draft)" as UC01
  usecase "UC-02\nกรอกข้อมูลฟอร์ม 7 ขั้นตอน" as UC02
  usecase "UC-03\nบันทึกร่างชั่วคราว\n(Save Draft)" as UC03
  usecase "UC-04\nส่งคำขออนุมัติ\n(Submit Proposal)" as UC04
  usecase "UC-05\nดูสถานะและรหัสอ้างอิง" as UC05
  usecase "UC-06\nแก้ไขร่างที่ถูกส่งกลับ\n(Revise Returned Draft)" as UC06

  ' ===== ฟอร์ม 7 ขั้นตอน =====
  package "ฟอร์ม 7 ขั้นตอน" {
    usecase "Step 1\nข้อมูลทั่วไปโครงการ\n(ชื่อ / แผนก / ประเภท / ลำดับ / Tag)" as S1
    usecase "Step 2\nวัตถุประสงค์และขอบเขต\n(Objective / Scope / Outcome / Stakeholder)" as S2
    usecase "Step 3\nการเชื่อมโยงนโยบายและแผนแม่บท\n(ยุทธศาสตร์ / นโยบาย / ระดับความสอดคล้อง)" as S3
    usecase "Step 4\nตัวชี้วัด KPI\n(เพิ่มได้ไม่จำกัด อย่างน้อย 1 รายการ)" as S4
    usecase "Step 5\nแผนและงบประมาณ\n(Timeline / Budget / Team)" as S5
    usecase "Step 6\nการประเมินความเสี่ยง\n(5 ด้าน + Risk Score + Mitigation)" as S6
    usecase "Step 7\nเอกสารแนบและยืนยันการส่ง\n(File Attach + Checkbox 2 ข้อ)" as S7
  }

  ' ===== Extension Points =====
  usecase "ลบ KPI\n(พร้อม confirmation dialog)" as EXT_KPI
  usecase "บังคับกรอก Mitigation Plan\n(เมื่อ Risk อยู่ในระดับ สูง / วิกฤต)" as EXT_MIT
  usecase "แจ้งเตือนงบประมาณ\nเกินเกณฑ์ที่กำหนด" as EXT_BUDG

  ' ===== การจัดการข้อมูลโครงการ =====
  package "การจัดการข้อมูลโครงการ (Data Management)" {
    usecase "UC-07\nค้นหาและกรองโครงการ\n(Search / Filter / Sort)" as UC07
    usecase "UC-08\nดูรายการโครงการทั้งหมด\n(Project List + Pagination)" as UC08
    usecase "UC-09\nลบร่างโครงการ\n(เฉพาะสถานะ Draft)" as UC09
    usecase "UC-10\nคัดลอกโครงการ\n(Duplicate — สร้าง Draft ใหม่)" as UC10
    usecase "UC-11\nExport ข้อมูลโครงการ\n(PDF / Excel)" as UC11
    usecase "UC-12\nดูประวัติการแก้ไข\n(Audit Log / Change History)" as UC12
  }

  ' ===== Extension Points ของ Data Management =====
  usecase "กรองตามหลายเงื่อนไข\n(แผนก / ประเภท / สถานะ / ช่วงวันที่)" as EXT_FILTER
  usecase "ยืนยันการลบ\n(Soft Delete + ไม่สามารถกู้คืนได้)" as EXT_DEL_CONFIRM

  ' ===== Admin: Master Data Management =====
  package "Admin — Master Data Management" {
    usecase "UC-13\nเพิ่ม KPI Master\n(ชื่อ / คำอธิบาย / หน่วย / ประเภท)" as UC13
    usecase "UC-14\nแก้ไข KPI Master\n(snapshot โครงการที่ส่งแล้ว)" as UC14
    usecase "UC-15\nลบ / ปิดใช้งาน KPI Master" as UC15
    usecase "UC-16\nจัดการ Master\nแผนยุทธศาสตร์ (CRUD)" as UC16
    usecase "UC-17\nจัดการ Master\nTag โครงการ (CRUD)" as UC17
    usecase "UC-18\nจัดการ Master\nหมวดงบประมาณ (CRUD)" as UC18
    usecase "UC-19\nจัดการ Master\nแหล่งงบประมาณ (CRUD)" as UC19
    usecase "UC-20\nจัดการ Master\nนโยบายองค์กร (CRUD)" as UC20
  }

  ' ===== Admin: System Configuration =====
  package "Admin — System Metadata / Configuration" {
    usecase "UC-21\nกำหนดเกณฑ์งบประมาณ\n(Budget Threshold per Level)" as UC21A
    usecase "UC-21\nกำหนดค่า Draft & Auto-save\n(Expiry / Warning / Interval)" as UC21B
    usecase "UC-21\nกำหนดค่าไฟล์แนบ\n(ขนาด / ประเภทไฟล์)" as UC21C
    usecase "UC-21\nกำหนด Approval Routing\n(Approver / Fallback)" as UC21D
    usecase "UC-21\nจัดการ Email Template\n(เปิด/ปิด / Placeholder)" as UC21E
    usecase "UC-21\nดู Configuration History\n(Audit Log การตั้งค่า)" as UC21F
  }

  ' ===== Shared Extension Points (Master Data) =====
  usecase "ตรวจสอบชื่อซ้ำ\n(case-insensitive)" as EXT_MD_DUP
  usecase "Snapshot โครงการที่ส่งแล้ว\n(ป้องกันผลกระทบย้อนหลัง)" as EXT_MD_SNAP
  usecase "ตรวจสอบการใช้งาน\nก่อนลบ / ปิดใช้งาน" as EXT_MD_USAGE

  ' ===== การทำงานอัตโนมัติของระบบ =====
  package "การทำงานอัตโนมัติของระบบ" {
    usecase "บันทึกร่างอัตโนมัติ\n(ทุก 30 วินาที)" as SYS1
    usecase "ตรวจสอบ Validation\nทุก Field บังคับใน 7 Step" as SYS2
    usecase "สร้างรหัสอ้างอิง\nรูปแบบ PRJ-YYYY-NNNN" as SYS3
    usecase "ส่ง Email แจ้งเตือน\n(Proposer + Approver ระดับ 1)" as SYS4
    usecase "คำนวณอัตโนมัติ\n(ระยะเวลา / งบรวม / Risk Score)" as SYS5
    usecase "แจ้งเตือนร่างใกล้หมดอายุ\n(15 วันก่อนครบ 90 วัน)" as SYS6
    usecase "บันทึก Audit Log\n(ทุกการเปลี่ยนแปลงข้อมูล)" as SYS7
    usecase "สร้างไฟล์ Export\n(PDF / Excel อัตโนมัติ)" as SYS8
  }
}

' ===== Proposer → Main UCs =====
Proposer --> UC01
Proposer --> UC02
Proposer --> UC03
Proposer --> UC04
Proposer --> UC05
Proposer --> UC06

' ===== Proposer → Data Management UCs =====
Proposer --> UC07
Proposer --> UC08
Proposer --> UC09
Proposer --> UC10
Proposer --> UC11
Proposer --> UC12

' ===== Admin → Master Data UCs =====
Admin --> UC13
Admin --> UC14
Admin --> UC15
Admin --> UC16
Admin --> UC17
Admin --> UC18
Admin --> UC19
Admin --> UC20

' ===== Admin → System Configuration =====
Admin --> UC21A
Admin --> UC21B
Admin --> UC21C
Admin --> UC21D
Admin --> UC21E
Admin --> UC21F

' ===== System → Auto Functions =====
System --> SYS1
System --> SYS2
System --> SYS3
System --> SYS4
System --> SYS5
System --> SYS6
System --> SYS7
System --> SYS8

' ===== UC02 <<include>> ทุก Step =====
UC02 ..> S1 : <<include>>
UC02 ..> S2 : <<include>>
UC02 ..> S3 : <<include>>
UC02 ..> S4 : <<include>>
UC02 ..> S5 : <<include>>
UC02 ..> S6 : <<include>>
UC02 ..> S7 : <<include>>

